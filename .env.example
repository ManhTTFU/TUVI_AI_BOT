# ─────────────────────────────────────────────────────────────────────────────
# Deepseek (OpenAI compatible)
# ─────────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Số call Deepseek đồng thời tối đa từ server (production: 8-16)
AI_CONCURRENCY=8

# ─────────────────────────────────────────────────────────────────────────────
# API server
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=4100
API_BASE_URL=http://localhost:4100

# ─────────────────────────────────────────────────────────────────────────────
# Web (Next.js) — note: NEXT_PUBLIC_* MUST also exist in apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# ─────────────────────────────────────────────────────────────────────────────
# Storage (filesystem cache fallback, sẽ migrate vào DB)
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ─────────────────────────────────────────────────────────────────────────────
# Database — Postgres (Neon free tier: https://neon.tech)
# Lấy connection string từ Neon dashboard, dạng: postgres://user:pass@ep-xxx.neon.tech/db?sslmode=require
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/db?sslmode=require
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# Auth.js v5 (NextAuth)
# ─────────────────────────────────────────────────────────────────────────────
# Required: generate bằng `openssl rand -base64 32` hoặc https://generate-secret.vercel.app/32
AUTH_SECRET=change-me-to-a-long-random-string
# Khi deploy production phải set NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_URL=http://localhost:3100

# Google OAuth — lấy từ https://console.cloud.google.com (OAuth Client ID, type Web)
# Authorized redirect URI: http://localhost:3100/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth — https://developers.facebook.com/apps
# Trong app: Add Product → Facebook Login → Settings → Valid OAuth Redirect URIs:
#   http://localhost:3100/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Email magic link (tuỳ chọn — bỏ trống nếu chỉ dùng Google)
# Có thể dùng SMTP Gmail, SendGrid, Resend, v.v.
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Diễn Cầm Tam Thế <noreply@example.com>"

# ─────────────────────────────────────────────────────────────────────────────
# Casso (backup auto reconciliation — KHÔNG bật trừ khi cần)
# Hướng dẫn: https://docs.casso.vn — webhook URL cấu hình thành /api/casso/webhook
# ─────────────────────────────────────────────────────────────────────────────
CASSO_ENABLED=false
CASSO_API_KEY=
CASSO_WEBHOOK_SECRET=
